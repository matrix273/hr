# Environment Configuration Example
# Copy this file to .env and update with your actual values

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Embedding Model Configuration
# ===== 本地部署（推荐，需要启动本地服务）=====
#QWEN_EMBEDDING_URL=http://localhost:8010/v1/embeddings
#QWEN_EMBEDDING_API_KEY=not_required

# ===== 云端 API - 阿里通义千问 =====
QWEN_EMBEDDING_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
QWEN_EMBEDDING_API_KEY=your_dashscope_api_key_here
# Embedding model name (用于云端 API)
QWEN_EMBEDDING_MODEL=text-embedding-v3

# Reranker Model Configuration
# ===== 本地部署 - Qwen3-Reranker-0.6B（推荐）=====
#QWEN_RERANKER_URL=http://localhost:8001/v1/rerank
#QWEN_RERANKER_API_KEY=not_required
#QWEN_RERANKER_MODEL=Qwen3-Reranker-0.6B

# ===== 云端 API - 阿里通义千问 =====
QWEN_RERANKER_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
QWEN_RERANKER_API_KEY=your_dashscope_api_key_here
QWEN_RERANKER_MODEL=qwen3-rerank

# LLM Configuration - 阿里通义千问
QWEN_LLM_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_LLM_API_KEY=your_dashscope_api_key_here
QWEN_LLM_MODEL=qwen-plus

# LLM Configuration - DeepSeek
DEEPSEEK_LLM_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_LLM_API_KEY=your_deepseek_api_key_here
DEEPSEEK_LLM_MODEL=deepseek-chat

# LLM Configuration - 字节豆包
DOUBAO_LLM_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions
DOUBAO_LLM_API_KEY=your_doubao_api_key_here
DOUBAO_LLM_MODEL=doubao-seed-2-0-pro-260215

# 默认使用云端 阿里通义千问 LLM（更稳定）
LLM_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
LLM_API_KEY=your_dashscope_api_key_here
LLM_MODEL=qwen-plus

# Application Configuration
INDEX_NAME=resume_index
COLLECTION_NAME=resumes

# FastAPI Configuration
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=pgadmin
POSTGRES_PASSWORD=pgadmin
POSTGRES_DB=hr

# JWT Configuration
SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# SMTP Configuration（邮箱验证码服务）
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your_smtp_auth_code
SMTP_FROM_NAME=AI简历筛选系统

# Admin email for contact form notifications
ADMIN_EMAIL=your_admin_email@example.com
